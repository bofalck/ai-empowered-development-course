{
  "name": "ai-empowered-development-course",
  "version": "1.0.0",
  "description": "Todo app demo for multi-agent parallel development",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint app.js",
    "lint:css": "stylelint styles.css",
    "lint:fix": "eslint app.js --fix && stylelint styles.css --fix",
    "figma:sync": "node figma-sync.js"
  },
  "keywords": [
    "todo",
    "demo",
    "multi-agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.53.4",
    "@vitest/ui": "^4.0.18",
    "eslint": "^8.54.0",
    "jsdom": "^28.1.0",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "svelte": "^5.53.7",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "date-fns": "^4.1.0",
    "vibe-kanban-web-companion": "^0.0.5"
  }
}
